# ============================================
# NovaMed - Git Ignore Configuration
# ============================================

# ── Sensitive Credentials ──────────────────
.env
.env.local
.env.production
firebase_key.json
agentic-pharmacy-*.json
credentials/
*.pem
*.key

# ── Python ─────────────────────────────────
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node.js / Frontend ─────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Databases & Storage ────────────────────
chroma_db/
*.db
*.sqlite
*.sqlite3

# ── Temporary Files ────────────────────────
temp_*
tmp/
uploads/
*.tmp
*.log

# ── Build Artifacts ────────────────────────
*.msi
*.zip
*.tar.gz
node/

# ── IDE & Editor ───────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS Files ───────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Firebase ───────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log

# ── Testing ────────────────────────────────
coverage/
.coverage
htmlcov/
.pytest_cache/

# ── Misc ───────────────────────────────────
*.bak
*.backup